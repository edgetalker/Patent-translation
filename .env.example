# ==============================================
# PatentTranslation 统一环境变量配置文件
# ==============================================
# 复制此文件为 .env 并填入你的API密钥

# API服务配置
API_HOST=0.0.0.0
API_PORT=8080

# LLM API配置
LLM_API_KEY=your_api_key
LLM_BASE_URL=your_llm_url
LLM_MODEL_NAME=your_model_names

# 分块参数
MAX_CHUNK_LENGTH=6000
OVERLAP_LENGTH=1000
MAX_RETRIES=3
RETRY_DELAY=2

# 术语提取配置
MAX_TERMS=60
MAX_INJECT_TERMS=25
WINDOW_SIZE=8000
WINDOW_OVERLAP=2000
MIN_TERM_FREQUENCY=1

# Qdrant配置
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 性能配置
TRANSLATION_TEMPERATURE=0.3
TERMINOLOGY_TEMPERATURE=0.3
MAX_TOKEN=8000

# ==============================================
# Embedding 服务配置
# ==============================================

# 使用魔搭社区 (推荐)
EMBED_BASE_URL=https://api-inference.modelscope.cn/v1/
EMBED_API_KEY=your_api_key
VECTOR_SIZE=1024

# 使用服务器部署模型
# EMBED_BASE_URL=your_base_url
# VECTOR_SIZE=1024

# ==============================================
# Qdrant 向量数据库配置
# ==============================================

# 使用Qdrant云服务（推荐）
QDRANT_URL=your_qdrant_url
QDRANT_API_KEY=your_api_key

# 使用本地Qdrant（需要Docker）
# QDRANT_HOST=http://localhost:6333